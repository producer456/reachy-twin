# reachy-twin config -- copy to .env and fill in. (.env is gitignored)

# --- Claude brain ("Hey Claude") ---
# Leave ANTHROPIC_API_KEY blank to use the Claude Code CLI on your subscription
# (no API cost). Set it to use the Anthropic API directly instead.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Marcus brain ("Hey Marcus") -- your own LLM endpoint ---
# POST {"message": "..."} -> SSE stream of {"text": <cumulative>} ending {"done": true}
# On the same host: http://localhost:PORT  | over a network: http://HOST:PORT
MARCUS_URL=

# --- Speech-to-text ---
WHISPER_MODEL=base.en
WHISPER_COMPUTE=int8

# --- Voices (Kokoro) ---
CLAUDE_VOICE=am_michael
MARCUS_VOICE=af_heart
